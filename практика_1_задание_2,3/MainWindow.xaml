<Window x:Class="практика_1_задание_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:практика_1_задание_2"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="800">
    <Grid Margin="0, 0, 2, 0">

        <StackPanel x:Name="Task1_Panel" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top" Width="318" Grid.ColumnSpan="2" Margin="242,100,232,0" Visibility="Visible">
            <Label Content="Магазин" Background="Aqua" FontSize="20" HorizontalAlignment="Center" Foreground="White" Height="40" Width="318"/>
            <TextBox x:Name="ProductName" ToolTip="Название продукта" FontSize="20" Height="30" TextWrapping="Wrap" Background="LightGray"/>
            <TextBox x:Name="ProductPrice" ToolTip="Цена продукта" FontSize="20" Height="30" TextWrapping="Wrap" Background="LightGray"/>
            <TextBox x:Name="ProductCount" ToolTip="кол-во продукта" FontSize="20" Height="30" TextWrapping="Wrap" Background="LightGray"/>
            <DataGrid x:Name="Grid" AutoGenerateColumns="False" SelectionMode="Extended" ToolTip="Список" FontSize="20" Height="418" Background="LightGray" IsReadOnly="True" Width="316" RenderTransformOrigin="0.5,0.5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Наименование" Binding="{Binding Name}"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price}"/>
                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Count}"/>
                </DataGrid.Columns>

            </DataGrid>

            <Button Content="Добавить" FontSize="16" Foreground="White" Click="Add_Click" Background="Aqua" Height="30"/>
            <Button Content="Продать" FontSize="16" Foreground="White" Click="Sell_Click" Background="Coral" Height="30"/>
            <Button Content="Поиск" FontSize="16" Foreground="White" Click="Search_Click" Background="Aqua" Height="30"/>
        </StackPanel>

        <StackPanel x:Name="Task1_Gains_Panel" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top" Width="318" Grid.ColumnSpan="2" Margin="242,60,232,0">
            <Label x:Name="profit_label" Content="Прибыль:" Background="Aqua" FontSize="20" HorizontalAlignment="Center" Foreground="White" Height="40" Width="318"/>
        </StackPanel>
    </Grid>
</Window>
