<Window x:Class="практика_1_задание_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:практика_1_задание_2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="0, 0, 2, 0">
        <Menu HorizontalAlignment="Left" Height="95" VerticalAlignment="Top" Width="100">
            <MenuItem Header="Отобразить лист товаров" Click="Product_list_Click"/>
            <MenuItem Header="Создать товар" Click="Create_Product_Click"/>
            <MenuItem Header="Купить товар" Click="Find_Prosuct_Click"/>
            <Separator/>
            <MenuItem Header="Выход" Click="Exit_Click"  Width="100"/>
        </Menu>

        <StackPanel x:Name="create_product_panel" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top" Width="318" Margin="242,50,232,0" Visibility="Hidden">
            <Label Content="Создание продуктов" Background="Aqua" FontSize="20" HorizontalAlignment="Center" Foreground="White" Height="40" Width="318"/>
            <TextBox x:Name="Product" ToolTip="Наименование товара" IsReadOnly="False" FontSize="20" Height="85" TextWrapping="Wrap" Background="LightGray"/>
            <TextBox x:Name="Price" ToolTip="Стоимость товара" IsReadOnly="False" FontSize="20" Height="85" TextWrapping="Wrap" Background="LightGray"/>
            <TextBox x:Name="Count" ToolTip="Количество товара" IsReadOnly="False" FontSize="20" Height="85" TextWrapping="Wrap" Background="LightGray"/>
            <Button Content="Добавить товар" FontSize="16" Foreground="White" Click="Add_Product_Click" Background="Aqua" Height="30"/>
        </StackPanel>

        <StackPanel x:Name="find_product_panel" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top" Width="318" Margin="242,50,232,0" Visibility="Hidden">
            <Label Content="Поиск товаров" Background="Aqua" FontSize="20" HorizontalAlignment="Center" Foreground="White" Height="40" Width="318"/>
            <TextBox x:Name="Product_to_find" ToolTip="Наименование товара, который необходимо купить" IsReadOnly="False" FontSize="20" Height="85" TextWrapping="Wrap" Background="LightGray"/>
            <Button Content="Купить товар" FontSize="16" Foreground="White" Click="Find_Click" Background="Aqua" Height="30"/>
        </StackPanel>

        <DataGrid x:Name="list_products" AutoGenerateColumns="False" ToolTip="Список" FontSize="20" Height="418" Background="LightGray" IsReadOnly="True" Width="316" RenderTransformOrigin="0,5,0,5">
            <DataGridTextColumn Header="Название" Binding="{Binding ElementName=Product}"/>
            <DataGridTextColumn Header="Цена" Binding="{Binding ElementName=Price}"/>
            <DataGridTextColumn Header="Количество" Binding="{Binding ElementName=Count}"/>
        </DataGrid>
    </Grid>
</Window>
